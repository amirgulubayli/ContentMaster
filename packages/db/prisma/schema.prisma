generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  active
  paused
}

enum ConnectorMode {
  api_auth
  session_auth
  hybrid_auth
}

enum AutomationMode {
  manual_review
  assisted_auto
  full_auto
}

enum SessionHealth {
  healthy
  warning
  expired
  revoked
}

enum AuthStatus {
  not_started
  configured
  certified
}

enum AuditStatus {
  success
  warning
  failed
}

enum QueueType {
  publish
  edit
  comment_reply
  dm_reply
  session_refresh
}

enum MediaKind {
  source_video
  b_roll_video
  image
  audio
  transcript
  document
  other
}

enum ProcessingStatus {
  pending
  processing
  ready
  failed
}

enum EditJobStatus {
  queued
  analyzing
  rendering
  completed
  failed
}

model Project {
  id                       String    @id @default(cuid())
  slug                     String    @unique
  name                     String
  description              String
  voice                    String
  status                   ProjectStatus
  dailyOptimizationEnabled Boolean   @default(true)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  accounts                 PlatformAccount[]
  contents                 ContentItem[]
  mediaAssets              MediaAsset[]
  editJobs                 EditJob[]
}

model PlatformAccount {
  id                String          @id @default(cuid())
  projectId         String
  platform          String
  handle            String
  displayName       String
  connectorMode     ConnectorMode
  automationMode    AutomationMode
  sessionHealth     SessionHealth
  authStatus        AuthStatus      @default(not_started)
  lastAuthRefreshAt DateTime?
  lastPostAt        DateTime?
  sessionRequired   Boolean         @default(false)
  openClawEnabled   Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  features          AccountFeature[]
  credentials       AccountCredential[]
  sessionVault      SessionVaultRecord[]
  comments          CommentThread[]
  dmThreads         DmThread[]
  publishJobs       PublishJob[]
  alerts            Alert[]
  setup             AccountSetup?
  editJobs          EditJob[]
}

model AccountSetup {
  id             String          @id @default(cuid())
  accountId      String          @unique
  connectorMode  ConnectorMode
  automationMode AutomationMode
  authStatus     AuthStatus      @default(not_started)
  openClawEnabled Boolean        @default(false)
  apiConfig      Json
  sessionConfig  Json
  notes          String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  account        PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model AccountFeature {
  id        String          @id @default(cuid())
  accountId String
  feature   String
  enabled   Boolean         @default(true)
  account   PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, feature])
}

model AccountCredential {
  id          String          @id @default(cuid())
  accountId   String
  secretType  String
  secretValue String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  account     PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model SessionVaultRecord {
  id                   String          @id @default(cuid())
  accountId            String
  profileObjectKey     String?
  encryptedBundle      String
  version              Int             @default(1)
  health               SessionHealth
  stabilityScore       Int             @default(0)
  lastValidatedAt      DateTime?
  revokedAt            DateTime?
  expiresAt            DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  account              PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model ContentItem {
  id            String       @id @default(cuid())
  projectId     String
  title         String
  body          String
  contentType   String
  source        String
  status        String
  metadata      Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  variants      ContentVariant[]
  editJobs      EditJob[]
}

model ContentVariant {
  id            String      @id @default(cuid())
  contentItemId String
  platform      String
  caption       String
  mediaType     String
  metadata      Json
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
}

model PublishJob {
  id            String          @id @default(cuid())
  accountId     String
  queueType     QueueType
  status        String
  scheduledFor  DateTime
  owner         String
  payload       Json
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  account       PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model CommentThread {
  id            String          @id @default(cuid())
  accountId     String
  platformRef   String
  authorHandle  String
  body          String
  status        String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  account       PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model DmThread {
  id            String          @id @default(cuid())
  accountId     String
  platformRef   String
  counterpart   String
  lastMessage   String
  status        String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  account       PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Alert {
  id          String          @id @default(cuid())
  accountId   String?
  severity    String
  title       String
  message     String
  createdAt   DateTime        @default(now())
  account     PlatformAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
}

model AuditEvent {
  id          String      @id @default(cuid())
  actor       String
  action      String
  subject     String
  status      AuditStatus
  detail      String
  createdAt   DateTime    @default(now())
}

model MediaAsset {
  id                 String           @id @default(cuid())
  projectId          String
  title              String
  description        String
  mediaKind          MediaKind
  mimeType           String
  originalFilename   String
  bucket             String
  objectKey          String           @unique
  sizeBytes          Int
  durationSeconds    Float?
  tags               Json
  transcriptStatus   ProcessingStatus @default(pending)
  transcript         String?
  transcriptChecksum String?
  analysisSummary    String?
  sentiment          String?
  keywords           Json?
  highlights         Json?
  embedding          Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  project            Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceForJobs      EditJob[]        @relation("EditJobSourceAsset")
  jobLinks           EditJobAsset[]
}

model EditJob {
  id                String        @id @default(cuid())
  projectId         String
  accountId         String?
  contentItemId     String?
  title             String
  sourceAssetId     String
  includeCaptions   Boolean       @default(true)
  status            EditJobStatus @default(queued)
  instructions      String
  aspectRatio       String
  renderTemplate    String
  transcriptSnapshot String?
  selectedHighlights Json?
  subtitleStyle     Json?
  renderPlan        Json?
  outputBucket      String?
  outputObjectKey   String?
  outputMimeType    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  account           PlatformAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contentItem       ContentItem?  @relation(fields: [contentItemId], references: [id], onDelete: SetNull)
  sourceAsset       MediaAsset    @relation("EditJobSourceAsset", fields: [sourceAssetId], references: [id], onDelete: Restrict)
  brollAssets       EditJobAsset[]
}

model EditJobAsset {
  id          String     @id @default(cuid())
  editJobId   String
  mediaAssetId String
  role        String
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  editJob     EditJob    @relation(fields: [editJobId], references: [id], onDelete: Cascade)
  mediaAsset  MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([editJobId, mediaAssetId, role])
}
